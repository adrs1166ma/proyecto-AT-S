        "operation": "executeQuery",
        "query": "INSERT INTO bot_clientes.clientes (nombres, nombre_comercial, ruc, direccion, distrito)\nVALUES ($1, $1, $2, $3, $4)\nON CONFLICT (ruc) WHERE ruc IS NOT NULL DO UPDATE SET\n  nombre_comercial = EXCLUDED.nombre_comercial,\n  direccion = EXCLUDED.direccion,\n  distrito = EXCLUDED.distrito,\n  updated_at = NOW()\nRETURNING id",
        "options": {
          "queryReplacement": "={{ [$json.nombre, $json.ruc, $json.direccion, $json.distrito] }}"
        }
      },
