      "id": "cb01-gen1-0024-0024-000000000024",
      "name": "Obtener Numero Cert",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [250, 1200],
      "credentials": {
        "postgres": {
          "id": "zq4GDVSwUY2kETtI",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const d = $('Combinar y Determinar Accion').first().json;\nconst numCert = $('Obtener Numero Cert').first().json.numero_certificado;\nconst cd = d.certData;\n\nconst payload = {\n  numero_certificado: numCert,\n  tipo: cd.tipo,\n  cliente: cd.cliente,\n  tipo_agente: cd.tipo_agente,\n  prueba_hidrostatica: cd.prueba_hidrostatica || false,\n  fecha_prueba_hidrostatica: cd.fecha_prueba_hidrostatica || null,\n  fecha_emision: cd.fecha_emision,\n  extintores: cd.extintores\n};\n\nreturn [{ json: { chatId: d.chatId, payload, numeroCert: numCert } }];"
      },
      "id": "cb01-gen2-0025-0025-000000000025",
      "name": "Construir Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 1200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://proyecto-at-s.onrender.com/generar-certificado",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "ats2026antashely" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify($json.payload) }}",
        "options": { "timeout": 60000 }
      },
      "id": "cb01-gen3-0026-0026-000000000026",
      "name": "Llamar Servicio Python",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [650, 1200]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst chatId = $('Construir Payload').first().json.chatId;\nconst numCert = $('Construir Payload').first().json.numeroCert;\n\nconst pdfBinary = await this.helpers.prepareBinaryData(\n  Buffer.from(response.pdf_base64, 'base64'),\n  `${numCert}.pdf`,\n  'application/pdf'\n);\n\nconst docxBinary = await this.helpers.prepareBinaryData(\n  Buffer.from(response.docx_base64, 'base64'),\n  `${numCert}.docx`,\n  'application/vnd.openxmlformats-officedocument.wordprocessingml.document'\n);\n\nreturn [{\n  json: { chatId, numCert },\n  binary: { pdfFile: pdfBinary, docxFile: docxBinary }\n}];"
      },
      "id": "cb01-gen4-0027-0027-000000000027",
      "name": "Preparar Archivos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 1200]
    },
    {
      "parameters": {
        "resource": "file",
        "operation": "sendDocument",
        "chatId": "={{ $json.chatId }}",
        "binaryData": true,
        "binaryPropertyName": "pdfFile",
