        "output": "={{ ['INICIAR','CERT_CLIENTE','CERT_TIPO_CB','CERT_AGENTE_CB','CERT_EXTINTORES','CERT_HIDRO_CB','CERT_CONFIRMAR_CB'].indexOf($json.accion) }}"
      },
      "id": "cb01-rout-0005-0005-000000000005",
