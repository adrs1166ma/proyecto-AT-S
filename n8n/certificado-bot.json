    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO bot_clientes.registro_borrador (chat_id, campo_editando, backup_texto, estado)\nVALUES ({{ $json.chatId }}, 'CERT_CLIENTE', '{}', 'EDICION')\nON CONFLICT (chat_id) DO UPDATE SET\n  campo_editando = 'CERT_CLIENTE',\n  backup_texto = '{}',\n  updated_at = NOW();",
        "options": {}
      },
